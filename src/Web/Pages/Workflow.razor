@page "/"
@page "/workflow"

<PageTitle>Workflow</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4" Elevation="1">
            <MudText Typo="Typo.h5" Class="mb-3">Project Workflow</MudText>

            <MudForm @ref="_form" Model="_model">
                <MudGrid>
                    <MudItem xs="12" sm="8">
                        <MudTextField @bind-Value="_model.ProjectNumber" Label="Project Number" For="@(() => _model.ProjectNumber)"
                                      Variant="Variant.Outlined" Immediate="true" Required="true" RequiredError="Project number is required" />
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex align-center">
                        <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary" Disabled="_starting" OnClick="StartGenerationAsync">
                            Start Generation
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudForm>

            @if (!string.IsNullOrWhiteSpace(_status))
            {
                <MudAlert Class="mt-3" Severity="@_statusSeverity">@_status</MudAlert>
            }
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="5">
        <ProjectValidationPanel ProjectNumber="@_model.ProjectNumber" />
    </MudItem>

    <MudItem xs="12" md="6">
        <FileUploadPanel ProjectNumber="@_model.ProjectNumber" />
    </MudItem>

    <MudItem xs="12" md="6">
        @if (!string.IsNullOrWhiteSpace(_activeJobId))
        {
            <JobTimeline JobId="@_activeJobId" />
        }
        else
        {
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.body2">Start a generation job to see timeline status updates.</MudText>
            </MudPaper>
        }
    </MudItem>

    <MudItem xs="12">
        <DraftEditor ProjectNumber="@_model.ProjectNumber" />
    </MudItem>
</MudGrid>

@code {
    [Inject] public IHttpClientFactory HttpClientFactory { get; set; } = default!;

    private MudForm? _form;
    private readonly WorkflowModel _model = new();

    private bool _starting;
    private string? _activeJobId;
    private string? _status;
    private Severity _statusSeverity = Severity.Info;

    private async Task StartGenerationAsync()
    {
        if (_form is null)
        {
            return;
        }

        await _form.Validate();
        if (!_form.IsValid)
        {
            _statusSeverity = Severity.Warning;
            _status = "Enter a valid project number before starting generation.";
            return;
        }

        _starting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("ApiClient");
            var response = await client.PostAsJsonAsync("/api/workflows/start", new { projectNumber = _model.ProjectNumber });
            if (!response.IsSuccessStatusCode)
            {
                _statusSeverity = Severity.Error;
                _status = $"Generation failed to start: {(int)response.StatusCode} {response.ReasonPhrase}";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<StartJobResponse>() ?? new StartJobResponse(string.Empty, "Queued");
            _activeJobId = payload.JobId;
            _statusSeverity = Severity.Success;
            _status = $"Generation started. Job {payload.JobId} is {payload.Status}.";
        }
        catch (Exception ex)
        {
            _statusSeverity = Severity.Error;
            _status = $"Failed to start generation: {ex.Message}";
        }
        finally
        {
            _starting = false;
        }
    }

    private sealed class WorkflowModel
    {
        [Required]
        [RegularExpression("^[A-Za-z0-9-]{4,20}$", ErrorMessage = "Use 4-20 letters, numbers, or dashes.")]
        public string ProjectNumber { get; set; } = string.Empty;
    }

    private sealed record StartJobResponse(string JobId, string Status);
}
